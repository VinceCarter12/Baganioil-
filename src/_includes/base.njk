<!DOCTYPE html>
<html lang="en">
<head>
	<!-- Meta -->
	<meta charset="utf-8">
	<meta http-equiv="X-UA-Compatible" content="IE=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1">
	<meta name="description" content="{{ description | default(site.description) }}">
	<meta name="keywords" content="{{ keywords | default(site.keywords) }}">
	<meta name="author" content="Bagani Oil">
	<!-- Page Title -->
    <title>{{ title }}{% if title != "Bagani Oil" %} - Bagani Oil{% endif %}</title>
	<!-- Favicon Icon -->
	<link rel="shortcut icon" type="image/x-icon" href="/images/favicon.png">
	<!-- Google Fonts Css-->
	<link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@200..800&display=swap" rel="stylesheet">
	<!-- Bootstrap Css -->
	<link href="/css/bootstrap.min.css" rel="stylesheet" media="screen">
	<!-- SlickNav Css -->
	<link href="/css/slicknav.min.css" rel="stylesheet">
	<!-- Swiper Css -->
	<link rel="stylesheet" href="/css/swiper-bundle.min.css">
	<!-- Font Awesome Icon Css-->
	<link href="/css/all.css" rel="stylesheet" media="screen">
	<!-- Animated Css -->
	<link href="/css/animate.css" rel="stylesheet">
    <!-- Magnific Popup Core Css File -->
	<link rel="stylesheet" href="/css/magnific-popup.css">
	<!-- Mouse Cursor Css File -->
	<link rel="stylesheet" href="/css/mousecursor.css">
	<!-- Main Custom Css -->
	<link href="/css/custom.css" rel="stylesheet" media="screen">
	<!-- Leaflet CSS (loaded globally so map container is sized correctly) -->
	<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
	<!-- Netlify Identity Widget -->
	<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body data-page="{{ activePage }}">

    {% include "preloader.njk" %}

    <!-- Fixed header wrapper: topbar + navbar -->
    <div id="bagani-header-wrap">
        {% include "topbar.njk" %}
        {% include "header.njk" %}
    </div>
    <!-- Spacer so content doesn't hide under fixed header -->
    <div id="header-spacer"></div>

    {{ content | safe }}

    {% include "footer.njk" %}

    <!-- Jquery Library File -->
    <script src="/js/jquery-3.7.1.min.js"></script>
    <!-- Bootstrap js file -->
    <script src="/js/bootstrap.min.js"></script>
    <!-- Validator js file -->
    <script src="/js/validator.min.js"></script>
    <!-- SlickNav js file -->
    <script src="/js/jquery.slicknav.js"></script>
    <!-- Swiper js file -->
    <script src="/js/swiper-bundle.min.js"></script>
    <!-- Counter js file -->
    <script src="/js/jquery.waypoints.min.js"></script>
    <script src="/js/jquery.counterup.min.js"></script>
    <!-- Isotop js file -->
	<script src="/js/isotope.min.js"></script>
    <!-- Magnific js file -->
    <script src="/js/jquery.magnific-popup.min.js"></script>
    <!-- SmoothScroll -->
    <script src="/js/SmoothScroll.js"></script>
    <!-- Parallax js -->
    <script src="/js/parallaxie.js"></script>
    <!-- MagicCursor js file -->
    <script src="/js/gsap.min.js"></script>
    <script src="/js/magiccursor.js"></script>
    <!-- Text Effect js file -->
    <script src="/js/SplitText.js"></script>
    <script src="/js/ScrollTrigger.min.js"></script>
    <!-- YTPlayer js File -->
    <script src="/js/jquery.mb.YTPlayer.min.js"></script>
    <!-- Wow js file -->
    <script src="/js/wow.min.js"></script>
    <!-- Main Custom js file -->
    <script src="/js/function.js"></script>

    <!-- Floating Navbar Script -->
    <script>
    (function() {
      var wrap = document.getElementById('bagani-header-wrap');
      var spacer = document.getElementById('header-spacer');

      function syncSpacer() {
        if (spacer && wrap) spacer.style.height = wrap.offsetHeight + 'px';
      }

      function onScroll() {
        var scrollY = window.scrollY || window.pageYOffset;
        if (scrollY > 40) {
          wrap.classList.add('scrolled');
        } else {
          wrap.classList.remove('scrolled');
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', syncSpacer);
      document.addEventListener('DOMContentLoaded', function() {
        syncSpacer();
        onScroll();

        // Nike-style search drawer toggle
        var searchToggle = document.getElementById('nikeSearchToggle');
        var searchDrawer = document.getElementById('nikeSearchDrawer');
        var searchClose = document.getElementById('nikeSearchClose');
        var searchInput = document.getElementById('nikeSearchInput');

        if (searchToggle && searchDrawer) {
          searchToggle.addEventListener('click', function() {
            searchDrawer.classList.toggle('open');
            if (searchDrawer.classList.contains('open') && searchInput) {
              setTimeout(function() { searchInput.focus(); }, 100);
            }
          });
        }
        if (searchClose && searchDrawer) {
          searchClose.addEventListener('click', function() {
            searchDrawer.classList.remove('open');
          });
        }
      });
      // re-sync after fonts/images load
      window.addEventListener('load', syncSpacer);
    })();
    </script>

    <!-- Language Toggle Script -->
    <script>
      // Swap all elements that have data-en and data-tl attributes
      function applyLang(lang) {
        document.querySelectorAll('[data-en]').forEach(function(el) {
          el.textContent = lang === 'tl' ? (el.getAttribute('data-tl') || el.getAttribute('data-en')) : el.getAttribute('data-en');
        });
        var btn = document.getElementById('langToggle');
        if (btn) {
          btn.textContent = lang === 'tl' ? 'TL' : 'EN';
          btn.style.color = lang === 'tl' ? '#121212' : '#FFC107';
          btn.style.background = lang === 'tl' ? '#FFC107' : 'none';
        }
        document.documentElement.setAttribute('lang', lang === 'tl' ? 'tl' : 'en');
        localStorage.setItem('bagani-lang', lang);
      }

      function toggleLang() {
        var current = localStorage.getItem('bagani-lang') || 'en';
        applyLang(current === 'en' ? 'tl' : 'en');
      }

      // Apply saved preference on load
      document.addEventListener('DOMContentLoaded', function() {
        var saved = localStorage.getItem('bagani-lang') || 'en';
        if (saved === 'tl') applyLang('tl');
      });
    </script>

    <!-- Netlify Identity Redirect -->
    <script>
      if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", function(user) {
          if (!user) {
            window.netlifyIdentity.on("login", function() {
              document.location.href = "/admin/";
            });
          }
        });
      }
    </script>

    {% if site.facebookPageId and site.facebookPageId != "YOUR_FACEBOOK_PAGE_ID" %}
    <!-- Custom Messenger Chat Widget -->
    <style>
      .bagani-chat-wrap { position: fixed; bottom: 28px; right: 28px; z-index: 9999; display: flex; flex-direction: column; align-items: flex-end; gap: 12px; }
      /* Popup card */
      .bagani-chat-popup {
        width: 300px; background: #fff; border-radius: 16px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.18);
        overflow: hidden; transform: scale(0.85) translateY(20px);
        opacity: 0; pointer-events: none;
        transition: opacity 0.25s ease, transform 0.25s ease;
        transform-origin: bottom right;
      }
      .bagani-chat-popup.open { opacity: 1; transform: scale(1) translateY(0); pointer-events: all; }
      .bagani-chat-popup-header {
        background: linear-gradient(135deg, #0084ff 0%, #0066cc 100%);
        padding: 20px; display: flex; align-items: center; gap: 14px;
      }
      .bagani-chat-popup-avatar {
        width: 48px; height: 48px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.4);
        object-fit: cover; flex-shrink: 0;
      }
      .bagani-chat-popup-info { flex: 1; }
      .bagani-chat-popup-name { color: #fff; font-weight: 700; font-size: 15px; margin: 0; }
      .bagani-chat-popup-status { color: rgba(255,255,255,0.8); font-size: 12px; display: flex; align-items: center; gap: 5px; margin-top: 2px; }
      .bagani-chat-popup-status::before { content: ''; width: 7px; height: 7px; background: #44ff88; border-radius: 50%; display: inline-block; }
      .bagani-chat-close-btn { background: rgba(255,255,255,0.2); border: none; color: #fff; width: 28px; height: 28px; border-radius: 50%; cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; transition: background 0.2s; }
      .bagani-chat-close-btn:hover { background: rgba(255,255,255,0.35); }
      .bagani-chat-popup-body { padding: 20px; }
      .bagani-chat-bubble { background: #f0f0f0; border-radius: 18px 18px 18px 4px; padding: 12px 16px; font-size: 14px; color: #333; line-height: 1.5; margin-bottom: 16px; }
      .bagani-chat-start-btn {
        display: flex; align-items: center; justify-content: center; gap: 10px;
        width: 100%; padding: 13px; border-radius: 10px;
        background: linear-gradient(135deg, #0084ff, #0066cc);
        color: #fff; font-weight: 700; font-size: 14px;
        text-decoration: none; transition: opacity 0.2s; border: none; cursor: pointer;
      }
      .bagani-chat-start-btn:hover { opacity: 0.88; color: #fff; }
      /* FAB button */
      .bagani-chat-fab {
        width: 58px; height: 58px; border-radius: 50%;
        background: linear-gradient(135deg, #0084ff, #0066cc);
        border: none; cursor: pointer; display: flex; align-items: center; justify-content: center;
        box-shadow: 0 4px 20px rgba(0,132,255,0.45);
        transition: transform 0.2s, box-shadow 0.2s;
        position: relative;
      }
      .bagani-chat-fab:hover { transform: scale(1.08); box-shadow: 0 6px 28px rgba(0,132,255,0.55); }
      .bagani-chat-fab svg { width: 28px; height: 28px; fill: #fff; transition: transform 0.3s; }
      .bagani-chat-fab.open svg.icon-msg { transform: scale(0) rotate(90deg); }
      .bagani-chat-fab svg.icon-close { position: absolute; transform: scale(0) rotate(-90deg); transition: transform 0.3s; }
      .bagani-chat-fab.open svg.icon-close { transform: scale(1) rotate(0); }
      /* Pulse ring */
      .bagani-chat-fab::before {
        content: ''; position: absolute; inset: -6px; border-radius: 50%;
        border: 2px solid rgba(0,132,255,0.5);
        animation: baganiPulse 2s ease-out infinite;
      }
      @keyframes baganiPulse {
        0% { transform: scale(1); opacity: 0.7; }
        100% { transform: scale(1.55); opacity: 0; }
      }
      /* Tooltip */
      .bagani-chat-tooltip {
        position: absolute; right: 70px; bottom: 50%; transform: translateY(50%);
        background: #111; color: #fff; font-size: 12px; font-weight: 600;
        padding: 6px 12px; border-radius: 6px; white-space: nowrap;
        opacity: 0; pointer-events: none; transition: opacity 0.2s;
      }
      .bagani-chat-tooltip::after { content: ''; position: absolute; left: 100%; top: 50%; transform: translateY(-50%); border: 5px solid transparent; border-left-color: #111; }
      .bagani-chat-fab:hover .bagani-chat-tooltip { opacity: 1; }
      /* Badge */
      .bagani-chat-badge {
        position: absolute; top: -2px; right: -2px;
        width: 18px; height: 18px; border-radius: 50%;
        background: #ff4444; border: 2px solid #fff;
        font-size: 10px; font-weight: 700; color: #fff;
        display: flex; align-items: center; justify-content: center;
      }
    </style>

    <div class="bagani-chat-wrap" id="baganiChatWrap">
      <!-- Popup -->
      <div class="bagani-chat-popup" id="baganiChatPopup">
        <div class="bagani-chat-popup-header">
          <img class="bagani-chat-popup-avatar" src="/images/bagani-icon.png" alt="Bagani Oil" onerror="this.style.display='none'">
          <div class="bagani-chat-popup-info">
            <p class="bagani-chat-popup-name">Bagani Oil</p>
            <span class="bagani-chat-popup-status">Typically replies instantly</span>
          </div>
          <button class="bagani-chat-close-btn" id="baganiChatClose" aria-label="Close">&#x2715;</button>
        </div>
        <div class="bagani-chat-popup-body">
          <div class="bagani-chat-bubble">Hi! 👋 How can we help you with Bagani Oil? Ask us about products, dealers, or orders.</div>
          <a href="https://m.me/{{ site.facebookPageId }}" target="_blank" rel="noopener" class="bagani-chat-start-btn">
            <svg viewBox="0 0 24 24" width="18" height="18" fill="white"><path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.908 1.438 5.504 3.688 7.2V22l3.37-1.85c.9.248 1.853.381 2.842.381 5.523 0 10-4.145 10-9.288C22 6.145 17.523 2 12 2zm1.007 12.516l-2.548-2.717-4.97 2.717 5.467-5.8 2.61 2.717 4.907-2.717-5.466 5.8z"/></svg>
            Continue on Messenger
          </a>
        </div>
      </div>
      <!-- FAB -->
      <button class="bagani-chat-fab" id="baganiChatFab" aria-label="Chat with us">
        <span class="bagani-chat-tooltip">Chat with us</span>
        <div class="bagani-chat-badge">1</div>
        <!-- Messenger icon -->
        <svg class="icon-msg" viewBox="0 0 24 24"><path d="M12 2C6.477 2 2 6.145 2 11.243c0 2.908 1.438 5.504 3.688 7.2V22l3.37-1.85c.9.248 1.853.381 2.842.381 5.523 0 10-4.145 10-9.288C22 6.145 17.523 2 12 2zm1.007 12.516l-2.548-2.717-4.97 2.717 5.467-5.8 2.61 2.717 4.907-2.717-5.466 5.8z"/></svg>
        <!-- Close icon -->
        <svg class="icon-close" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12" stroke="white" stroke-width="2.5" stroke-linecap="round" fill="none"/></svg>
      </button>
    </div>

    <script>
      (function() {
        var fab = document.getElementById('baganiChatFab');
        var popup = document.getElementById('baganiChatPopup');
        var closeBtn = document.getElementById('baganiChatClose');
        var badge = fab ? fab.querySelector('.bagani-chat-badge') : null;
        var isOpen = false;

        function toggleChat() {
          isOpen = !isOpen;
          popup.classList.toggle('open', isOpen);
          fab.classList.toggle('open', isOpen);
          if (badge && isOpen) badge.style.display = 'none';
        }

        if (fab) fab.addEventListener('click', toggleChat);
        if (closeBtn) closeBtn.addEventListener('click', function(e) { e.stopPropagation(); toggleChat(); });

        // Auto-open after 4 seconds on first visit
        if (!sessionStorage.getItem('baganiChatSeen')) {
          setTimeout(function() {
            if (!isOpen) { toggleChat(); sessionStorage.setItem('baganiChatSeen', '1'); }
          }, 4000);
        }
      })();
    </script>
    {% endif %}
    <!-- Sanity Live: client-side content fetching -->
    <script src="/js/sanity-live.js"></script>
</body>
</html>
