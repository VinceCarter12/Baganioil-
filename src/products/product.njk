---
pagination:
  data: productsList
  size: 1
  alias: product
permalink: "/products/{{ product.slug }}/"
layout: base.njk
activePage: products
eleventyComputed:
  title: "{{ product.name }}"
  pageHeaderTitle: "{{ product.name | safe }}"
---

<!-- Page Header Start -->
<div class="page-header product-page-header parallaxie">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-12">
                <div class="page-header-box">
                    <h1 class="text-anime-style-2" data-cursor="-opaque">{{ product.name }} <span>{{ product.line }}</span></h1>
                    <nav class="wow fadeInUp">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item"><a href="/">home</a></li>
                            <li class="breadcrumb-item"><a href="/products/">products</a></li>
                            <li class="breadcrumb-item active" aria-current="page">{{ product.name }}</li>
                        </ol>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Header End -->

<!-- Page Product Single Start -->
<div class="page-service-single">
    <div class="container">
        <div class="row">
            <!-- Sidebar -->
            <div class="col-lg-4">
                <div class="service-sidebar">
                    <!-- Product Lines List -->
                    <div class="service-catagery-list wow fadeInUp">
                        <h3>Product Lines</h3>
                        <ul>
                            <li><a href="/products/?filter=amihan">Amihan — Motorcycle Oils</a></li>
                            <li><a href="/products/?filter=laon">Laon — Engine Oils</a></li>
                            <li><a href="/products/?filter=aman">Aman — Gear Oils</a></li>
                            <li><a href="/products/?filter=anitun">Anitun — Transmission Fluids</a></li>
                        </ul>
                    </div>

                    <!-- Sidebar CTA -->
                    <div class="sidebar-cta-box wow fadeInUp" data-wow-delay="0.25s">
                        <div class="sidebar-cta-logo">
                            <img src="/images/bagani-logo.png" alt="Bagani">
                        </div>
                        <div class="sidebar-cta-Body">
                            <div class="sidebar-cta-content">
                                <h3>Need <span>help?</span></h3>
                                <p>Looking for the right oil for your motorcycle? Contact us for assistance.</p>
                            </div>
                            <div class="sidebar-cta-contact-list">
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-phone-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.phone }}</h3>
                                    </div>
                                </div>
                                <div class="sidebar-cta-contact-item">
                                    <div class="icon-box">
                                        <img src="/images/icon-mail-accent.svg" alt="">
                                    </div>
                                    <div class="cta-contact-item-title">
                                        <h3>{{ site.email }}</h3>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main Content -->
            <div class="col-lg-8">
                <div class="service-single-content">

                    <!-- Product Image -->
                    <div class="service-featured-image">
                        <figure class="image-anime reveal" style="background: linear-gradient(135deg, #FFF9E6 0%, #FFF3CC 100%); padding: 40px; text-align: center; border-radius: 10px;">
                            <img src="{{ product.image }}" alt="Bagani {{ product.name }}" style="max-height: 400px; width: auto; object-fit: contain;">
                        </figure>
                    </div>

                    <!-- Product Info -->
                    <div class="service-entry">
                        <!-- Product Badge & Title -->
                        <div style="margin-bottom: 20px;">
                            <span class="product-line" style="font-size: 13px; padding: 4px 14px; background: #FFC107; color: #121212; font-weight: 700; border-radius: 3px; text-transform: uppercase; letter-spacing: 1px;">{{ product.line }}</span>
                        </div>

                        <h2 class="wow fadeInUp">{{ product.name }} — <span>{{ product.specs["Oil Type"] }}</span></h2>

                        <p class="wow fadeInUp">{{ product.description }}</p>

                        <p class="wow fadeInUp" data-wow-delay="0.2s">{{ product.description2 }}</p>

                        <!-- Product Specifications Table -->
                        <h2 class="wow fadeInUp" data-wow-delay="0.3s">Product <span>Specifications</span></h2>

                        <table class="product-specs-table wow fadeInUp" data-wow-delay="0.4s">
                            <tbody>
                                {% for key, value in product.specs %}
                                <tr>
                                    <th>{{ key }}</th>
                                    <td>{{ value }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>

                        <!-- Key Features -->
                        <h2 class="wow fadeInUp" data-wow-delay="0.4s">Key <span>Features</span></h2>

                        <div class="service-entry-box">
                            {% for feature in product.features %}
                            <div class="service-entry-item">
                                <div class="icon-box">
                                    <img src="{{ feature.icon }}" alt="">
                                </div>
                                <div class="service-entry-item-content">
                                    <h3>{{ feature.title }}</h3>
                                    <p>{{ feature.desc }}</p>
                                </div>
                            </div>
                            {% endfor %}
                        </div>

                        <!-- Applications -->
                        <h2 class="wow fadeInUp" data-wow-delay="0.4s">Recommended <span>Applications</span></h2>

                        <ul>
                            {% for app in product.applications %}
                            <li>{{ app }}</li>
                            {% endfor %}
                        </ul>

                    </div>

                    <!-- Product FAQ -->
                    {% if product.faqs.length > 0 %}
                    <div class="our-faq-section">
                        <div class="section-title">
                            <h2 class="text-anime-style-3" data-cursor="-opaque">Frequently asked <span>questions</span></h2>
                        </div>

                        <div class="faq-accordion" id="faqaccordion">
                            {% for faq in product.faqs %}
                            <div class="accordion-item wow fadeInUp"{% if not loop.first %} data-wow-delay="{{ loop.index0 * 0.2 }}s"{% endif %}>
                                <h2 class="accordion-header" id="heading{{ loop.index }}">
                                    <button class="accordion-button{% if not loop.first %} collapsed{% endif %}" type="button" data-bs-toggle="collapse" data-bs-target="#collapse{{ loop.index }}" aria-expanded="{% if loop.first %}true{% else %}false{% endif %}" aria-controls="collapse{{ loop.index }}">
                                        {{ faq.q }}
                                    </button>
                                </h2>
                                <div id="collapse{{ loop.index }}" class="accordion-collapse collapse{% if loop.first %} show{% endif %}" aria-labelledby="heading{{ loop.index }}" data-bs-parent="#faqaccordion">
                                    <div class="accordion-body">
                                        <p>{{ faq.a }}</p>
                                    </div>
                                </div>
                            </div>
                            {% endfor %}
                        </div>
                    </div>
                    {% endif %}

                    <!-- Back to Products Button -->
                    <div class="about-content-btn wow fadeInUp" style="margin-top: 30px;">
                        <a href="/products/" class="btn-default"><span>← Back to All Products</span></a>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>
<!-- Page Product Single End -->
